#!/usr/bin/bash
set -euo pipefail

runtime_dir=/run/hytale
console_fifo="$runtime_dir/console.in"

install -d -m 0750 -o hytale -g hytale "$runtime_dir"

if [[ -p "$console_fifo" ]]; then
  rm -f "$console_fifo"
fi

mkfifo -m 0660 "$console_fifo"
chown hytale:hytale "$console_fifo"

cleanup() {
  rm -f "$console_fifo"
}

trap cleanup EXIT

# Keep the FIFO open read/write so the launcher keeps a live stdin stream
# even when no admin command is being injected. Opening write-only blocks until
# a reader exists, which would deadlock before the launcher ever starts.
exec 3<>"$console_fifo"

exec /usr/libexec/hytale-launcher <"$console_fifo"
